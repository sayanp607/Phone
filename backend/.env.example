# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/remote-device-control
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/remote-device-control

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS Configuration (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# Socket.io Configuration
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
